---
interface Props {
  title: string;
  description: string;
  icon: string;
  accentColor: string;
  href: string;
  status: 'live' | 'coming-soon';
}

const { title, description, icon, accentColor, href, status } = Astro.props;
---

<article
  class="group relative overflow-hidden rounded-xl border border-border bg-card p-6 transition-all hover:shadow-lg hover:border-primary/50"
  style={`--accent-color: ${accentColor}`}
>
  <div class="flex items-start gap-4">
    <div
      class="flex-shrink-0 w-12 h-12 rounded-lg flex items-center justify-center text-2xl"
      style={`background-color: ${accentColor}20`}
      aria-hidden="true"
    >
      {icon}
    </div>
    <div class="flex-1 space-y-2">
      <div class="flex items-center justify-between">
        <h3 class="text-xl font-display font-semibold">{title}</h3>
        {status === 'coming-soon' && (
          <span class="text-xs px-2 py-1 rounded bg-muted text-muted-foreground">
            Coming Soon
          </span>
        )}
      </div>
      <p class="text-muted-foreground">{description}</p>
      {status === 'live' && (
        <a
          href={href}
          class="inline-flex items-center text-sm font-medium hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
          style={`color: ${accentColor}`}
        >
          Launch App →
        </a>
      )}
    </div>
  </div>
</article>
