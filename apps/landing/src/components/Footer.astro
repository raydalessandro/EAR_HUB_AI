---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border mt-20">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-display font-semibold mb-4">EAR Hub</h3>
        <p class="text-sm text-muted-foreground">
          AI-powered tools for insight, resolution, and creativity.
        </p>
      </div>

      <div>
        <h4 class="font-medium mb-4">Applications</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://oracle.earhub.com"
              class="text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
            >
              Oracle Astrology
            </a>
          </li>
          <li>
            <a
              href="https://resolver.earhub.com"
              class="text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
            >
              Conflict Resolver
            </a>
          </li>
          <li>
            <a
              href="https://menu.earhub.com"
              class="text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
            >
              MenuAI
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-medium mb-4">Resources</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://github.com/your-org/ear-hub"
              class="text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
              rel="noopener noreferrer"
              target="_blank"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
            >
              Documentation
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
            >
              Support
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border text-center text-sm text-muted-foreground">
      <p>&copy; {currentYear} EAR Hub. Open source under MIT License.</p>
    </div>
  </div>
</footer>
