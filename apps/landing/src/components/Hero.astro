<section class="relative min-h-[80vh] flex items-center justify-center px-4">
  <div class="max-w-4xl mx-auto text-center space-y-6">
    <h1 class="text-5xl md:text-7xl font-display font-bold tracking-tight">
      EAR Hub
    </h1>
    <p class="text-xl md:text-2xl text-muted-foreground max-w-2xl mx-auto">
      AI-powered tools for insight, resolution, and creativity
    </p>
    <p class="text-lg text-muted-foreground max-w-xl mx-auto">
      Three specialized applications designed to help you understand yourself,
      resolve conflicts, and create inspired experiences.
    </p>
    <div class="pt-8">
      <a
        href="#apps"
        class="inline-flex items-center px-6 py-3 text-lg font-medium rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        aria-label="Explore applications"
      >
        Explore Apps
      </a>
    </div>
  </div>

  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-primary/5 to-transparent" aria-hidden="true"></div>
</section>
